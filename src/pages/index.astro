---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/urls';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))].sort();
---

<BaseLayout
  title="Sutra Sutra"
  description="Sutra Sutra blog with article list, tags, RSS and sitemap."
>
  <h1>Sutra Sutra</h1>

  <p>
    <a href={withBase('rss.xml')}>訂閱 RSS</a>
    {' · '}
    <a href={withBase('sitemap-index.xml')}>Sitemap</a>
  </p>

  {allTags.length > 0 && (
    <>
      <h2>分類 / Tags</h2>
      <p>
        {allTags.map((tag, i) => (
          <>
            <a href={withBase(`tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>
            {i < allTags.length - 1 ? ' ' : ''}
          </>
        ))}
      </p>
    </>
  )}

  <hr />

  <h2>文章列表</h2>
  <ul>
    {posts.map((post) => {
      const slug = post.id.replace(/\.md$/, '');
      return (
        <li>
          <a href={withBase(`posts/${slug}/`)}>{post.data.title}</a>
          <div class="meta">{post.data.pubDate.toLocaleDateString('zh-TW')} · {post.data.description}</div>
          {(post.data.tags?.length ?? 0) > 0 && (
            <div class="meta">
              {post.data.tags!.map((tag, i) => (
                <>
                  <a href={withBase(`tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>
                  {i < post.data.tags!.length - 1 ? ' ' : ''}
                </>
              ))}
            </div>
          )}
        </li>
      );
    })}
  </ul>
</BaseLayout>
